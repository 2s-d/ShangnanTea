<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shangnantea.mapper.UserNotificationMapper">
    <!-- 结果映射：与 user_notifications 表结构保持一致 -->
    <resultMap id="BaseResultMap" type="com.shangnantea.model.entity.message.UserNotification">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="sender_id" property="senderId"/>
        <result column="type" property="type"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="target_id" property="targetId"/>
        <result column="target_type" property="targetType"/>
        <result column="extra_data" property="extraData"/>
        <result column="is_read" property="isRead"/>
        <result column="create_time" property="createTime"/>
        <result column="read_time" property="readTime"/>
    </resultMap>

    <!-- 所有列：严格对应 teasystem.sql 中 user_notifications 的字段 -->
    <sql id="Base_Column_List">
        id, user_id, sender_id, type, title, content, target_id, target_type, extra_data, is_read, create_time, read_time
    </sql>

    <!-- 插入记录 -->
    <insert id="insert" parameterType="com.shangnantea.model.entity.message.UserNotification">
        INSERT INTO user_notifications (
            id, user_id, sender_id, type, title, content, target_id, target_type, extra_data, is_read, create_time, read_time
        ) VALUES (
            #{id}, #{userId}, #{senderId}, #{type}, #{title}, #{content},
            #{targetId}, #{targetType}, #{extraData}, #{isRead}, #{createTime}, #{readTime}
        )
    </insert>

    <!-- 根据主键删除记录 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM user_notifications WHERE id = #{id}
    </delete>

    <!-- 根据主键批量删除记录 -->
    <delete id="deleteByIds" parameterType="java.util.List">
        DELETE FROM user_notifications WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 根据主键更新记录 -->
    <update id="updateById" parameterType="com.shangnantea.model.entity.message.UserNotification">
        UPDATE user_notifications
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="senderId != null">sender_id = #{senderId},</if>
            <if test="type != null">type = #{type},</if>
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="targetId != null">target_id = #{targetId},</if>
            <if test="targetType != null">target_type = #{targetType},</if>
            <if test="extraData != null">extra_data = #{extraData},</if>
            <if test="isRead != null">is_read = #{isRead},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="readTime != null">read_time = #{readTime},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据主键查询记录 -->
    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_notifications
        WHERE id = #{id}
    </select>

    <!-- 根据主键批量查询记录 -->
    <select id="selectByIds" parameterType="java.util.List" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_notifications
        WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <!-- 查询所有记录 -->
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_notifications
    </select>

    <!-- 统计记录总数 -->
    <select id="count" resultType="java.lang.Long">
        SELECT COUNT(*) FROM user_notifications
    </select>

    <!-- 根据用户ID和类型查询通知列表（支持分页） -->
    <select id="selectByUserIdAndType" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM user_notifications
        WHERE user_id = #{userId}
        <if test="type != null and type != ''">
            AND type = #{type}
        </if>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!-- 统计用户的通知数量 -->
    <select id="countByUserIdAndType" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM user_notifications
        WHERE user_id = #{userId}
        <if test="type != null and type != ''">
            AND type = #{type}
        </if>
    </select>

    <!-- 统计用户的未读通知数量 -->
    <select id="countUnreadByUserIdAndType" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM user_notifications
        WHERE user_id = #{userId} AND (is_read IS NULL OR is_read = 0)
        <if test="type != null and type != ''">
            AND type = #{type}
        </if>
    </select>
</mapper> 